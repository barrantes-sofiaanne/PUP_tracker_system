{
  "$schema": "https://schema.railpack.com",
  "phpExtensions": ["gd"],
  "buildAptPackages": ["libpng-dev", "libjpeg62-turbo-dev", "libfreetype6-dev"],
  "steps": {
    "install": {
      "commands": [
        "docker-php-ext-configure gd --with-freetype --with-jpeg",
        "docker-php-ext-install -j$(nproc) gd"
      ]
    }
  }
}
